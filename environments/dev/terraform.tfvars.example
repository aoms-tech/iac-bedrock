# Copy to terraform.tfvars (gitignored) and adjust.

aws_region  = "us-east-1"
environment = "dev"
project_name = "brickeye-bedrock"

# Optional: constrain who can assume team IAM roles (default is account root).
# Set this false in production and define explicit principals below.
# allow_account_root_trust_principal = false
# team_role_trust_principals = [
#   "arn:aws:iam::123456789012:role/AWSReservedSSO_Developer_xxxxx",
# ]

# PrivateLink for bedrock + bedrock-runtime (requires VPC + private subnets).
# enable_bedrock_private_endpoints = true
# vpc_id             = "vpc-xxxxxxxx"
# private_subnet_ids = ["subnet-aaa", "subnet-bbb"]
# endpoint_allowed_principal_arns = [
#   "arn:aws:iam::123456789012:role/AWSReservedSSO_Developer_xxxxx",
# ]

# Minimal guardrail (HATE / VIOLENCE / SEXUAL filters at MEDIUM).
# enable_guardrail = true

# Optional: override model ARNs (use ListFoundationModels / console to confirm IDs in your region).
# model_invoke_resource_arns = [
#   "arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-5-haiku-20241022-v1:0",
# ]

# Same-account deployments: prod owns the Bedrock logging singleton.
# Set this to false once prod has been applied, so dev doesn't overwrite
# the account-level logging config.
# manage_logging_config = false

tags = {
  Team = "platform"
}
